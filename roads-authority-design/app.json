{
  "expo": {
    "name": "myRA App",
    "slug": "roads-authority-design",
    "version": "1.0.0",
    "icon": "./assets/launcher-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/ra_logo_v1.png",
      "resizeMode": "contain",
      "backgroundColor": "#00B4E6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.roadsauthority.design",
      "infoPlist": {
        "NSCameraUsageDescription": "Take a photo of road damage",
        "NSPhotoLibraryUsageDescription": "Choose a photo of road damage",
        "NSLocationWhenInUseUsageDescription": "Report location of road damage",
        "NSFaceIDUsageDescription": "Unlock your driving licence securely with Face ID."
      }
    },
    "android": {
      "icon": "./assets/launcher-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/launcher-icon.png",
        "backgroundColor": "#00B4E6"
      },
      "package": "com.roadsauthority.design",
      "softwareKeyboardLayoutMode": "resize",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-local-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/ra_logo_v1.png",
          "resizeMode": "contain",
          "backgroundColor": "#00B4E6",
          "imageWidth": 240
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      ]
    ],
    "web": {},
    "extra": {
      "eas": {
        "projectId": "c07c18a6-ea55-48e5-821d-b446767a7b57"
      }
    },
    "owner": "ra_dev"
  }
}
